# backend/.env.example
#
# Copy this file to backend/.env and fill in the values.
# Never commit backend/.env — it is listed in .gitignore.
#
# Quick start:
#   cp backend/.env.example backend/.env
#   # then edit backend/.env and replace placeholder values

# =============================================================================
# REQUIRED — server will not start without these
# =============================================================================

# MongoDB connection string.
# With docker compose: use the value below as-is.
# With MongoDB Atlas:  replace with your Atlas URI.
MONGO_URL=mongodb://localhost:27017/bridgebot

# MongoDB database name.
DB_NAME=bridgebot

# Secret key for signing JWT tokens. Must be at least 32 random bytes.
# Generate one with: openssl rand -hex 32
# WARNING: changing this invalidates all existing sessions.
JWT_SECRET=replace-with-openssl-rand-hex-32

# Superadmin account seeded on first startup.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# PostgreSQL/ParadeDB connection string.
# With docker compose: use the value below as-is (host port 5433).
# Without Docker:      change port to 5432 if running ParadeDB natively.
PARADEDB_URL=postgresql://postgres:secret@localhost:5433/postgres

# =============================================================================
# RECOMMENDED
# =============================================================================

# Anthropic API key — required for chat to work.
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# OPTIONAL — controls which subsystems start
# =============================================================================

# Deployment mode:
#   api    — FastAPI only. Best for local dev. No Discord credentials needed.
#   all    — FastAPI + Discord bot. Requires Discord credentials below.
#   worker — Discord bot only (pair with api replicas in production).
APP_MODE=api

# =============================================================================
# OPTIONAL — email (falls back to console log if not set)
# =============================================================================

# Resend API key for transactional email (verification, password reset).
# If not set, codes are printed to the server console instead.
# Get from: https://resend.com
RESEND_API_KEY=re_...

# =============================================================================
# OPTIONAL — Discord bot (only needed when APP_MODE=all or APP_MODE=worker)
# =============================================================================

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
