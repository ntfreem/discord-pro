# backend/.env.example
#
# Copy this file to backend/.env and fill in the values.
# Never commit backend/.env — it is listed in .gitignore.
#
#   cp backend/.env.example backend/.env

# =============================================================================
# REQUIRED INFRASTRUCTURE — the server will not start without these four.
# Everything else is an optional integration configurable from the admin UI.
# =============================================================================

# MongoDB — primary store for users, conversations, analytics, Discord config.
# With docker compose:  use the value below as-is.
# With MongoDB Atlas:   replace with your Atlas URI.
MONGO_URL=mongodb://localhost:27017/bridgebot
DB_NAME=bridgebot

# JWT signing secret. Must be at least 32 random bytes.
# Generate one with: openssl rand -hex 32
# WARNING: changing this invalidates all existing sessions.
JWT_SECRET=replace-with-openssl-rand-hex-32

# Superadmin account seeded on first startup.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# PostgreSQL/ParadeDB — primary store for knowledge sources with BM25 search.
# With docker compose:  use the value below as-is (host port 5433).
# Without Docker:       change port to 5432 if running ParadeDB natively.
PARADEDB_URL=postgresql://postgres:secret@localhost:5433/postgres

# =============================================================================
# APP_MODE — controls which subsystems start at runtime.
#
#   all    — FastAPI + Discord bot (if credentials are configured).
#            Discord is optional — the app starts cleanly without it and
#            logs a friendly message pointing to the admin UI.
#            RECOMMENDED for single-instance deployments (local or production).
#
#   api    — FastAPI only. No Discord bot, no Discord credentials needed.
#            Use this for API-only development or when scaling horizontally
#            as N replicas behind a load balancer.
#
#   worker — Discord bot only. Requires Discord credentials — fails fast
#            if not configured. Run exactly one instance per Discord app.
# =============================================================================
APP_MODE=all

# =============================================================================
# OPTIONAL INTEGRATIONS
# These can be left empty and configured later from the admin UI.
# Environment variables are fallbacks — DB config takes priority.
# =============================================================================

# Anthropic API key — required for chat to work, but not for startup.
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Resend API key — for transactional email (verification, password reset).
# If not set, codes are printed to the server console (fine for local dev).
# Get from: https://resend.com
RESEND_API_KEY=

# Discord integration — only needed when APP_MODE=all (with bot) or worker.
# Leave empty to run in API-only mode. Configure via admin UI at any time.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
